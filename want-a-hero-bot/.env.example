# ─────────────────────────────────────────────────────────────────────────────
# Want-A-Hero Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# The exact Discord role name that can run admin commands (case-sensitive)
ADMIN_ROLE_NAME=Hero Admin


# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite file (relative to the project root or absolute)
DB_PATH=data/hero_requests.db


# ── Logging ───────────────────────────────────────────────────────────────────
# Log directory and rotation settings
# Inline comments on value lines will break python-dotenv — keep values clean
LOG_DIR=logs
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=7


# ── Google Sheets (set GOOGLE_SHEETS_ENABLED=true to activate) ───────────────
GOOGLE_SHEETS_ENABLED=false

# Path to your Google service-account JSON key file
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# The ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
